generator client {

  provider = "prisma-client-js"

}



datasource db {

  provider  = "postgresql"

  url       = env("DATABASE_URL")

  directUrl = env("DIRECT_URL")

}



enum Role {

  HR_MANAGER

  ADMIN

}



enum EmployeeStatus {

  ACTIVE

  INACTIVE

  ON_LEAVE

}



enum JobStatus {

  PENDING

  PROCESSING

  COMPLETED

  FAILED

}



enum AuditAction {

  CREATE

  UPDATE

  DELETE

  BULK_ADJUST

  IMPORT

  EXPORT

}



model User {

  id        String   @id @default(uuid())

  email     String   @unique

  password  String

  firstName String   @map("first_name")

  lastName  String   @map("last_name")

  role      Role     @default(HR_MANAGER)

  isActive  Boolean  @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")

  updatedAt DateTime @updatedAt @map("updated_at")



  auditLogs       AuditLog[]

  refreshTokens   RefreshToken[]

  importJobs      ImportJob[]

  exportJobs      ExportJob[]

  salaryRevisions SalaryRevision[]



  @@map("users")

}



model Country {

  id           String     @id @default(uuid())

  code         String     @unique @db.Char(2)

  name         String     @db.VarChar(100)

  currencyCode String     @map("currency_code") @db.Char(3)

  employees    Employee[]



  @@map("countries")

}



model Department {

  id        String     @id @default(uuid())

  code      String     @unique @db.VarChar(20)

  name      String     @db.VarChar(100)

  employees Employee[]



  @@map("departments")

}



model JobGrade {

  id        String     @id @default(uuid())

  name      String     @db.VarChar(50)

  level     Int        @unique

  minSalary Decimal    @map("min_salary") @db.Decimal(12, 2)

  maxSalary Decimal    @map("max_salary") @db.Decimal(12, 2)

  employees Employee[]



  @@map("job_grades")

}



model Employee {

  id           String         @id @default(uuid())

  employeeCode String         @unique @map("employee_code")

  firstName    String         @map("first_name")

  lastName     String         @map("last_name")

  email        String         @unique

  phone        String?

  department   String

  position     String

  hireDate     DateTime       @map("hire_date")

  salary       Decimal?       @db.Decimal(10, 2)

  status       EmployeeStatus @default(ACTIVE)

  countryId    String?        @map("country_id")

  departmentId String?        @map("department_id")

  jobGradeId   String?        @map("job_grade_id")

  createdAt    DateTime       @default(now()) @map("created_at")

  updatedAt    DateTime       @updatedAt @map("updated_at")



  countryRef    Country?       @relation(fields: [countryId], references: [id], onDelete: SetNull)

  departmentRef Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  jobGradeRef   JobGrade?      @relation(fields: [jobGradeId], references: [id], onDelete: SetNull)

  salaryRecords SalaryRecord[]



  @@index([department, status])

  @@index([lastName, firstName])

  @@index([status])

  @@index([salary])

  @@map("employees")

}



model SalaryRecord {

  id            String    @id @default(uuid())

  employeeId    String    @map("employee_id")

  baseSalary    Decimal   @map("base_salary") @db.Decimal(12, 2)

  bonus         Decimal   @default(0) @db.Decimal(12, 2)

  allowances    Decimal   @default(0) @db.Decimal(12, 2)

  currencyCode  String    @default("USD") @map("currency_code") @db.Char(3)

  effectiveFrom DateTime  @map("effective_from") @db.Date

  effectiveTo   DateTime? @map("effective_to") @db.Date

  isCurrent     Boolean   @default(true) @map("is_current")

  createdAt     DateTime  @default(now()) @map("created_at")



  employee  Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  revisions SalaryRevision[]



  @@index([employeeId, isCurrent])

  @@index([employeeId, effectiveFrom(sort: Desc)])

  @@map("salary_records")

}



model SalaryRevision {

  id             String   @id @default(uuid())

  salaryRecordId String   @map("salary_record_id")

  employeeId     String   @map("employee_id")

  changedById    String?  @map("changed_by_id")

  fieldName      String   @map("field_name") @db.VarChar(50)

  oldValue       String   @map("old_value")

  newValue       String   @map("new_value")

  changedAt      DateTime @default(now()) @map("changed_at")



  salaryRecord SalaryRecord @relation(fields: [salaryRecordId], references: [id], onDelete: Cascade)

  changedBy    User?        @relation(fields: [changedById], references: [id], onDelete: SetNull)



  @@index([employeeId, changedAt(sort: Desc)])

  @@map("salary_revisions")

}



model AuditLog {

  id         String      @id @default(uuid())

  userId     String      @map("user_id")

  action     AuditAction

  entityType String      @map("entity_type") @db.VarChar(50)

  entityId   String      @map("entity_id")

  metadata   Json?

  createdAt  DateTime    @default(now()) @map("created_at")



  user User @relation(fields: [userId], references: [id], onDelete: Restrict)



  @@index([userId, createdAt(sort: Desc)])

  @@index([entityType, entityId])

  @@map("audit_logs")

}



model ImportJob {

  id          String    @id @default(uuid())

  userId      String    @map("user_id")

  fileKey     String    @map("file_key") @db.VarChar(500)

  status      JobStatus @default(PENDING)

  rowCount    Int?      @map("row_count")

  errorReport Json?     @map("error_report")

  createdAt   DateTime  @default(now()) @map("created_at")

  updatedAt   DateTime  @updatedAt @map("updated_at")



  user User @relation(fields: [userId], references: [id], onDelete: Restrict)



  @@index([userId, status])

  @@map("import_jobs")

}



model ExportJob {

  id        String    @id @default(uuid())

  userId    String    @map("user_id")

  fileKey   String    @map("file_key") @db.VarChar(500)

  status    JobStatus @default(PENDING)

  rowCount  Int?      @map("row_count")

  filters   Json?

  createdAt DateTime  @default(now()) @map("created_at")

  updatedAt DateTime  @updatedAt @map("updated_at")

  expiresAt DateTime? @map("expires_at")



  user User @relation(fields: [userId], references: [id], onDelete: Restrict)



  @@index([userId, status])

  @@map("export_jobs")

}



model RefreshToken {

  id        String    @id @default(uuid())

  userId    String    @map("user_id")

  tokenHash String    @map("token_hash") @db.VarChar(255)

  expiresAt DateTime  @map("expires_at")

  revokedAt DateTime? @map("revoked_at")

  createdAt DateTime  @default(now()) @map("created_at")



  user User @relation(fields: [userId], references: [id], onDelete: Cascade)



  @@index([tokenHash])

  @@index([userId])

  @@map("refresh_tokens")

}


